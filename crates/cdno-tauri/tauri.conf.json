{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cuaderno",
  "identifier": "in.agusti.cuaderno",
  "build": {
    "beforeDevCommand": {
      "cwd": "../../ui",
      "script": "bun run dev"
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "cwd": "../../ui",
      "script": "bun run build"
    },
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "cuaderno",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      },
      {
        "label": "capture",
        "url": "capture.html",
        "title": "capture",
        "width": 560,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
